# Server Configuration
# Enable/disable the local Web UI server (default: true)
SERVER_ENABLED=true
# Port where the Web UI server will listen (default: 8080)
SERVER_PORT=8080
# Optional password to protect the Web UI. Leave empty to disable authentication
SERVER_PASSWORD=
# Expose server to the local network (listen on 0.0.0.0 instead of 127.0.0.1) (default: false)
SERVER_EXPOSE_NETWORK=false

# Sessions
# Automatically generate session titles based on the first few user messages (default: true)
SESSION_AUTO_NAME=true
# Inactivity duration in minutes before a Telegram session is marked as expired (default: 30)
SESSION_EXPIRY_MIN=30
# Confirmation mode for plan execution (smart/always/never). Smart prompts on risky tools (default: smart)
PLAN_CONFIRMATION=smart

# Ollama Connection & Coordinator
# The base URL where local Ollama is running (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434
# The main coordinator model for general chat, history, tools, and final response (Required)
OLLAMA_DEFAULT_MODEL=
# Comma-separated list of models to pre-probe for capabilities at startup (Optional)
OLLAMA_PROBE_MODELS=

# Role-Specific Models (Fallback to main coordinator model if capabilities allow)
# Dedicated model with vision capabilities for image attachments (e.g. qwen2.5-coder:7b-instruct)
OLLAMA_MODEL_VISION=
# Dedicated model with audio capabilities for transcribing voice messages (e.g. gemma4:e2b)
OLLAMA_MODEL_AUDIO=
# Dedicated model for generating long-term memory embeddings (e.g. nomic-embed-text)
OLLAMA_MODEL_EMBED=
# Dedicated model for generating images via generate_image tool (e.g. flux)
OLLAMA_MODEL_IMAGE=
# Dedicated model for background reflection and sleep-mode learning (e.g. llama3.1)
OLLAMA_MODEL_LEARNING=
# Dedicated model for subagents, goal evaluation, and titles (e.g. qwen2.5:3b)
OLLAMA_MODEL_SUBAGENT=

# Model Inference Controls
# Number of inference steps for the image generation model (default: 4)
OLLAMA_IMAGE_STEPS=4
# Enable or disable reasoning/thinking blocks (e.g. for DeepSeek R1) (default: true)
OLLAMA_THINK_ENABLED=true
# Max output tokens allowed for Ollama completions (default: 16384)
OLLAMA_MAX_TOKENS=16384
# Max context window size. Set to 0 to use the model's default context limit
OLLAMA_MAX_CONTEXT=0

# Resource Limits
# Max execution timeout in minutes for subagent background tasks (default: 10)
SUBAGENT_TIMEOUT_MINUTES=10

# Telegram Channel Settings
# Telegram Bot API token obtained from @BotFather. Leave empty to disable Telegram channel
TELEGRAM_BOT_TOKEN=
# Comma-separated list of Telegram User IDs authorized to interact with the bot. Leave empty for public access
TELEGRAM_AUTHORIZED_IDS=
# Send a notification to authorized users when the bot process starts (default: false)
TELEGRAM_STARTUP_NOTIFICATION=false

# Persistence Paths
# Directory for the workspace sandbox where tools operate (default: workspace)
WORKSPACE_PATH=workspace
# Directory where session histories and attachments are stored (default: sessions)
SESSIONS_PATH=sessions
# Directory where the long-term semantic memory database is stored (default: memory)
MEMORY_PATH=memory
# Directory where custom reusable skills markdown files are stored (default: skills)
SKILLS_PATH=skills

# Sleep Mode Reflection
# Enable background reflection and optimization when user is inactive (default: false)
SLEEP_MODE_ENABLED=false
# Inactivity duration threshold before starting sleep mode (e.g., 30m, 1h) (default: 30m)
SLEEP_MODE_INACTIVITY_THRESHOLD=30m
# Delay to wait after activity before resuming sleep cycles (default: 10m)
SLEEP_MODE_RESUME_DELAY=10m
# Enable running subagents to assist with learning and reflection tasks (default: false)
SLEEP_MODE_SUBAGENTS_ENABLED=false

# Web Search Tool Settings
# Enable or disable the web_search tool (default: false)
WEB_SEARCH_ENABLED=false
# Comma-separated list of search providers to prioritize (e.g., brave,tavily,ddg) (default: ddg)
WEB_SEARCH_PRIORITY=ddg
# API key for Brave Search. Required if Brave is in priority list
WEB_SEARCH_BRAVE_API_KEY=
# API key for Tavily Search. Required if Tavily is in priority list
WEB_SEARCH_TAVILY_API_KEY=